# chemsmart agent provider configuration.
# Leave base_url empty to use the default chemsmart gateway for that provider.
active: __ACTIVE_PROVIDER__
providers:
    openai:
        type: openai
        api_key_env: OPENAI_API_KEY
        api_key: "__OPENAI_API_KEY__"
        model: gpt-5.4
        base_url: ""
        extra_headers: {}
    anthropic:
        type: anthropic
        api_key_env: ANTHROPIC_API_KEY
        api_key: "__ANTHROPIC_API_KEY__"
        model: claude-sonnet-4-6
        base_url: ""
        extra_headers: {}
    # Local merged chemsmart synthesizer. Two deployment shapes:
    #   - In-process (type: local) — loads a merged model on this machine.
    #     CUDA is fastest; MPS/CPU remain supported for local testing.
    #   - HTTP (type: openai with custom base_url) — point at a FastAPI shim
    #     running on Colab/another box; see chemsmart/agent/local/README.md.
    local_chemsmart_v13_1:
        type: local
        model: chemsmart-qwen2.5-coder-3b-instruct-v13_1
        base_model_id: Smilesjs/chemsmart-qwen2.5-coder-3b-instruct-v13_1
        # hf_token / hf_token_env are only consulted when the model is NOT
        # already in ~/.cache/huggingface/hub/. Leave blank once the cache is
        # populated.
        hf_token_env: HF_TOKEN
        hf_token: "__HF_TOKEN__"
        runtime: ""       # auto-detect: cuda | mps | cpu
        base_url: ""
        extra_headers: {}
