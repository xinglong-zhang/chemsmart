# chemsmart agent — LLM provider credentials
# Copy this file to api.env and fill in your keys.
# api.env is gitignored and will never be committed.

# Set AI_PROVIDER to either "openai" or "anthropic"
AI_PROVIDER=openai

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
